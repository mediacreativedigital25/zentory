{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access control",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "role": { "type": "string", "enum": ["SuperAdmin", "Administrator", "Admin 01 Manager Bisnis", "Admin 02 Kasir", "Customer"] },
        "tenantId": { "type": "string", "description": "ID of the tenant this user belongs to" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Tenant": {
      "title": "Tenant",
      "description": "A business entity/store in the multi-tenant system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subdomain": { "type": "string", "description": "Unique slug for subdomain access" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Suspended"] },
        "plan": { "type": "string", "enum": ["Free", "Pro", "Enterprise"] },
        "businessType": { "type": "string", "enum": ["Retail", "Service", "Mixed"] },
        "password": { "type": "string", "description": "Initial login password" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "subdomain", "status", "plan"]
    },
    "Service": {
      "title": "Service",
      "description": "Service offered for booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "integer", "description": "Duration in minutes" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "name", "price", "duration"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Appointment or service booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Completed", "Cancelled"] },
        "total": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "customerId", "serviceId", "date", "time", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial income or expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "type": { "type": "string", "enum": ["Income", "Expense"] },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "referenceId": { "type": "string", "description": "Optional ID of related order or booking" }
      },
      "required": ["tenantId", "type", "amount", "date"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory product item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "integer" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "name", "price", "stock"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "name"]
    },
    "Order": {
      "title": "Order",
      "description": "Sales order from customer or manual entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "orderId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "quantity": { "type": "integer" },
              "price": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Completed", "Cancelled"] },
        "type": { "type": "string", "enum": ["Manual", "Catalog"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "customerId", "items", "total", "status", "type"]
    }
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Business tenants"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Services for booking"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Service bookings"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial transactions"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory products"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Sales orders"
    }
  }
}
