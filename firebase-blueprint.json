{
  "entities": {
    "tenant": {
      "title": "Tenant",
      "description": "A business entity using the SaaS.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Business name" },
        "slug": { "type": "string", "description": "Subdomain slug" },
        "ownerId": { "type": "string", "description": "UID of the tenant admin" },
        "subscription": { "type": "string", "enum": ["free", "pro", "enterprise"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "settings": { "type": "object" }
      },
      "required": ["name", "slug", "ownerId"]
    },
    "user": {
      "title": "User",
      "description": "A user of the system.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["superadmin", "admin", "staff"] },
        "tenantId": { "type": "string", "description": "ID of the tenant they belong to (null for superadmin)" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLoginAt": { "type": "string", "format": "date-time" },
        "lastLogoutAt": { "type": "string", "format": "date-time" },
        "isOnline": { "type": "boolean" }
      },
      "required": ["email", "role"]
    },
    "product": {
      "title": "Product",
      "description": "Inventory item.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "barcode": { "type": "string" },
        "hpp": { "type": "number", "description": "Cost of Goods Sold" },
        "price": { "type": "number", "description": "Selling Price" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "warehouseId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["tenantId", "name", "price", "hpp"]
    },
    "category": {
      "title": "Category",
      "description": "Product category.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["tenantId", "name"]
    },
    "warehouse": {
      "title": "Warehouse",
      "description": "Storage location.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["tenantId", "name"]
    },
    "transaction": {
      "title": "Transaction",
      "description": "Sales record.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "type": { "type": "string", "enum": ["sale", "expense"] },
        "amount": { "type": "number" },
        "items": { "type": "array" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "userId": { "type": "string" },
        "transactionNumber": { "type": "string" },
        "bankAccountId": { "type": "string" }
      },
      "required": ["tenantId", "type", "amount", "date"]
    },
    "approval_request": {
      "title": "Approval Request",
      "description": "Request to change status of a cancelled order.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "orderId": { "type": "string" },
        "orderNumber": { "type": "string" },
        "requestedBy": { "type": "string" },
        "requestedAt": { "type": "string", "format": "date-time" },
        "targetStatus": { "type": "string", "enum": ["pending", "processing", "completed"] },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "resolvedBy": { "type": "string" },
        "resolvedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "orderId", "requestedBy", "targetStatus", "status"]
    },
    "daily_closing": {
      "title": "Daily Closing",
      "description": "Daily financial summary.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "totalSales": { "type": "number" },
        "totalCost": { "type": "number" },
        "totalExpenses": { "type": "number" },
        "grossProfit": { "type": "number" },
        "netProfit": { "type": "number" },
        "transactionCount": { "type": "number" },
        "charityAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["UNTUNG", "RUGI", "IMPAS"] },
        "closedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "totalSales", "grossProfit", "netProfit", "status"]
    },
    "expense_rule": {
      "title": "Expense Rule",
      "description": "Auto-fill rules for expenses.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "category": { "type": "string" },
        "defaultActivity": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "category", "defaultActivity"]
    },
    "bank_account": {
      "title": "Bank Account",
      "description": "Financial account for receiving payments.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string", "description": "e.g., BCA, Mandiri, QRIS, Cash" },
        "accountNumber": { "type": "string", "description": "Account number or identifier" },
        "accountHolder": { "type": "string", "description": "Name on account" },
        "type": { "type": "string", "enum": ["BANK", "QRIS", "CASH", "E-WALLET"] },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "name", "type"]
    },
    "supplier": {
      "title": "Supplier",
      "description": "Vendors and suppliers",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "contactName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "name"]
    },
    "purchase_request": {
      "title": "Purchase Request",
      "description": "Internal purchase requests",
      "type": "object",
      "properties": {
        "prNumber": { "type": "string" },
        "tenantId": { "type": "string" },
        "items": { "type": "array" },
        "requestedBy": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "converted"] },
        "reason": { "type": "string" }
      },
      "required": ["prNumber", "tenantId", "items", "requestedBy", "status"]
    },
    "purchase_order": {
      "title": "Purchase Order",
      "description": "Official purchase orders for suppliers",
      "type": "object",
      "properties": {
        "poNumber": { "type": "string" },
        "tenantId": { "type": "string" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "prId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "sent", "received", "cancelled"] }
      },
      "required": ["poNumber", "tenantId", "supplierId", "items", "totalAmount", "status"]
    },
    "goods_receipt": {
      "title": "Goods Receipt",
      "description": "Validation of incoming goods",
      "type": "object",
      "properties": {
        "grNumber": { "type": "string" },
        "tenantId": { "type": "string" },
        "poId": { "type": "string" },
        "poNumber": { "type": "string" },
        "supplierId": { "type": "string" },
        "items": { "type": "array" },
        "receivedBy": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "completed"] }
      },
      "required": ["grNumber", "tenantId", "poId", "items", "receivedBy", "status"]
    },
    "purchase_invoice": {
      "title": "Purchase Invoice",
      "description": "Supplier bills",
      "type": "object",
      "properties": {
        "piNumber": { "type": "string" },
        "tenantId": { "type": "string" },
        "poId": { "type": "string" },
        "poNumber": { "type": "string" },
        "supplierId": { "type": "string" },
        "amount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date-time" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["unpaid", "partial", "paid"] }
      },
      "required": ["piNumber", "tenantId", "poId", "amount", "dueDate", "status"]
    },
    "order": {
      "title": "Order",
      "description": "Customer order from catalog.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "orderNumber": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerAddress": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "paymentMethod": { "type": "string" }
      },
      "required": ["tenantId", "orderNumber", "customerName", "customerEmail", "customerAddress", "items", "totalAmount", "status", "date", "userId"]
    },
    "customer": {
      "title": "Customer",
      "description": "Client information.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "type": { "type": "string", "enum": ["umum", "langganan"] },
        "allowTempo": { "type": "boolean" },
        "tempoLimitDays": { "type": "number", "description": "Number of days for credit term" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "name", "type"]
    },
    "custom_domain": {
      "title": "Custom Domain",
      "description": "Custom domain mapping for tenants.",
      "type": "object",
      "properties": {
        "domain": { "type": "string" },
        "tenantId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "pending"] },
        "sslStatus": { "type": "string", "enum": ["valid", "invalid", "pending"] },
        "isPrimary": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["domain", "tenantId", "status", "isPrimary"]
    },
    "stock_log": {
      "title": "Stock Log",
      "description": "Audit trail for stock changes.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "type": { "type": "string", "enum": ["IN", "OUT", "ADJUSTMENT", "SALE", "PURCHASE", "CANCEL"] },
        "quantity": { "type": "number" },
        "previousStock": { "type": "number" },
        "currentStock": { "type": "number" },
        "referenceId": { "type": "string" },
        "referenceNumber": { "type": "string" },
        "note": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "productId", "type", "quantity", "previousStock", "currentStock", "userId", "createdAt"]
    },
    "coupon": {
      "title": "Coupon",
      "description": "Discount coupons for sales.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["percentage", "fixed"] },
        "value": { "type": "number" },
        "minPurchase": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "category": { "type": "string", "description": "Category ID or 'all'" },
        "usageLimit": { "type": "number" },
        "usedCount": { "type": "number" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "code", "type", "value", "startDate", "endDate", "isActive"]
    },
    "finance_invoice": {
      "title": "Finance Invoice",
      "description": "Subscription invoices for tenants.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "tenantName": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "planId": { "type": "string" },
        "planName": { "type": "string" },
        "amount": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "cancelled"] },
        "paymentMethod": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "userId", "planId", "total", "status", "invoiceNumber"]
    },
    "system_service": {
      "title": "System Service",
      "description": "Available services and packages in the system.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "features": { "type": "array" },
        "isEnabled": { "type": "boolean" },
        "type": { "type": "string", "enum": ["subscription", "addon"] },
        "icon": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "type", "isEnabled"]
    }
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": "tenant",
      "description": "Tenant configuration"
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "product",
      "description": "Product inventory"
    },
    "/categories/{categoryId}": {
      "schema": "category",
      "description": "Product categories"
    },
    "/warehouses/{warehouseId}": {
      "schema": "warehouse",
      "description": "Storage locations"
    },
    "/transactions/{transactionId}": {
      "schema": "transaction",
      "description": "Sales and expense records"
    },
    "/approval_requests/{requestId}": {
      "schema": "approval_request",
      "description": "Requests for status changes"
    },
    "/dailyClosings/{closingId}": {
      "schema": "daily_closing",
      "description": "Daily financial summaries"
    },
    "/expenseRules/{ruleId}": {
      "schema": "expense_rule",
      "description": "Auto-fill rules for expenses"
    },
    "/bank_accounts/{accountId}": {
      "schema": "bank_account",
      "description": "Bank accounts for payments"
    },
    "/suppliers/{supplierId}": {
      "schema": "supplier",
      "description": "Vendors and suppliers"
    },
    "/purchase_requests/{prId}": {
      "schema": "purchase_request",
      "description": "Internal purchase requests"
    },
    "/purchase_orders/{poId}": {
      "schema": "purchase_order",
      "description": "Official purchase orders"
    },
    "/goods_receipts/{grId}": {
      "schema": "goods_receipt",
      "description": "Validation of incoming goods"
    },
    "/purchase_invoices/{piId}": {
      "schema": "purchase_invoice",
      "description": "Supplier bills"
    },
    "/orders/{orderId}": {
      "schema": "order",
      "description": "Customer orders"
    },
    "/custom_domains/{domainId}": {
      "schema": "custom_domain",
      "description": "Custom domain mappings"
    },
    "/stock_logs/{logId}": {
      "schema": "stock_log",
      "description": "Stock mutation history"
    },
    "/coupons/{couponId}": {
      "schema": "coupon",
      "description": "Discount coupons"
    },
    "/customers/{customerId}": {
      "schema": "customer",
      "description": "Customer records"
    },
    "/finance_invoices/{invoiceId}": {
      "schema": "finance_invoice",
      "description": "Subscription invoices"
    },
    "/system_services/{serviceId}": {
      "schema": "system_service",
      "description": "System service catalog"
    }
  }
}
