rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // 1. Primitive Definitions & Helpers
    // -------------------------------------------------------------------------
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    // User profile lookup helper - optimized
    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    // Super Admin: hardcoded email or role 'superadmin'
    function isSuperAdmin() {
      return isSignedIn() && (
        ("email" in request.auth.token && request.auth.token.email == "mediacreativedigital25@gmail.com") ||
        (userExists() && getProfile().role == 'superadmin')
      );
    }

    // Tenant Isolation Helpers - consolidated
    function isTenantAdmin(tenantId) {
      return isSignedIn() && userExists() && 
             getProfile().tenantId == tenantId && 
             (getProfile().role in ['admin', 'owner']);
    }
    
    function isTenantStaff(tenantId) {
      return isSignedIn() && userExists() && 
             getProfile().tenantId == tenantId && 
             (getProfile().role in ['admin', 'staff', 'kasir', 'sales', 'owner']);
    }

    function getTenantId() {
      return userExists() ? getProfile().tenantId : null;
    }

    // -------------------------------------------------------------------------
    // 1.1 Validation Helpers (Eight Pillars)
    // -------------------------------------------------------------------------

    function isValidProduct(data) {
      return data.tenantId is string &&
             data.name is string && data.name.size() > 0 &&
             data.type in ['product', 'service', 'manual', 'booking', 'tunggal', 'variasi', 'grosir'];
    }

    function isValidOrder(data) {
      return data.tenantId is string &&
             data.orderNumber is string &&
             (data.totalAmount is number || data.total is number) &&
             data.items is list &&
             data.status is string;
    }

    function isValidStockLog(data) {
      return data.tenantId is string &&
             data.productId is string &&
             (data.qty is number || data.quantity is number) &&
             data.type in ['SALE', 'PURCHASE', 'ADJUSTMENT', 'TRANSFER', 'INITIAL', 'RETURN', 'IN', 'OUT', 'CANCEL'];
    }

    function isValidCounter(data) {
      return data.tenantId is string &&
             data.prefix is string &&
             data.sequence is number;
    }

    function isValidCustomer(data) {
      return data.tenantId is string &&
             data.name is string && data.name.size() > 0 &&
             (data.email is string || data.email == null);
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // 2. Tenants & Settings (Publicly browsable for catalogs, but only staff/superadmin can list all)
    // -------------------------------------------------------------------------
    
    match /global_settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /tenants/{tenantId} {
      allow read, list: if true; // Catalogs need to find the tenant by slug/id
      allow create: if isSuperAdmin() || (isSignedIn() && incoming().ownerId == request.auth.uid);
      allow update: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow delete: if isSuperAdmin();
    }

    // -------------------------------------------------------------------------
    // 3. User Profiles
    // -------------------------------------------------------------------------
    
    match /sales_codes/{codeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        isSuperAdmin() || 
        (userExists() && existing().tenantId != null && existing().tenantId == getTenantId())
      );
      
      allow list: if isSuperAdmin();
      
      allow create: if isSignedIn() && (
        request.auth.uid == userId || 
        isSuperAdmin() || 
        (incoming().tenantId != null && isTenantAdmin(incoming().tenantId))
      );
      
      allow update: if isSignedIn() && (
        isSuperAdmin() || 
        // Users can update their own profile, but NOT role or tenantId
        (request.auth.uid == userId && 
         !incoming().diff(existing()).affectedKeys().hasAny(['role', 'tenantId', 'uid', 'email'])) ||
        // Tenant admins can update roles within their tenant
        (existing().tenantId != null && isTenantAdmin(existing().tenantId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['role', 'displayName']))
      );
      
      allow delete: if isSuperAdmin() || (isSignedIn() && existing().tenantId != null && isTenantAdmin(existing().tenantId));
    }

    // -------------------------------------------------------------------------
    // 4. Products & Categories (Public for Catalogs)
    // -------------------------------------------------------------------------
    
    match /products/{productId} {
      allow read, list: if true; 
      allow create: if (isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId) && isValidProduct(incoming())));
      allow update: if isSuperAdmin() || (
        isSignedIn() && existing().tenantId == getTenantId() && isTenantStaff(existing().tenantId) && (
          // General staff update
          isValidProduct(incoming()) ||
          // Stock-only update (e.g. from checkout)
          (incoming().diff(existing()).affectedKeys().hasOnly(['stock'])) ||
          // Stock + Variants update
          (incoming().diff(existing()).affectedKeys().hasOnly(['stock', 'variants']))
        )
      );
      allow delete: if isSuperAdmin() || (isSignedIn() && isTenantStaff(existing().tenantId));
    }

    match /reviews/{reviewId} {
      allow read, list: if true;
      allow create: if true;
      allow update, delete: if isSuperAdmin() || (isSignedIn() && resource.data.tenantId != null && isTenantAdmin(resource.data.tenantId));
    }

    match /services/{serviceId} {
      allow read, list: if true;
      allow create: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
      allow update: if isSuperAdmin() || (isSignedIn() && existing().tenantId == getTenantId() && isTenantStaff(existing().tenantId));
      allow delete: if isSuperAdmin() || (isSignedIn() && isTenantStaff(existing().tenantId));
    }

    match /categories/{categoryId} {
      allow read, list: if true;
      allow write: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
    }

    match /service_categories/{categoryId} {
      allow read, list: if true;
      allow write: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
    }

    match /business_lines/{lineId} {
      allow read, list: if true;
      allow write: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
    }

    // -------------------------------------------------------------------------
    // 5. Transactions & Orders (Private)
    // -------------------------------------------------------------------------
    
    match /transactions/{transactionId} {
      allow read, list: if isSignedIn();
      allow create: if isSuperAdmin() || (isSignedIn() && (
        (isSignedIn() && isTenantStaff(incoming().tenantId)) || 
        (incoming().type == 'sale' && incoming().status == 'pending')
      ));
      allow update: if isSuperAdmin() || (isSignedIn() && isTenantStaff(resource.data.tenantId));
      allow delete: if isSuperAdmin() || (isSignedIn() && isTenantStaff(resource.data.tenantId));
    }

    match /bank_transfers/{transferId} {
      allow read, list: if isSignedIn();
      allow create: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
      allow update: if isSuperAdmin() || (isSignedIn() && isTenantStaff(resource.data.tenantId));
      allow delete: if isSuperAdmin() || (isSignedIn() && isTenantStaff(resource.data.tenantId));
    }

    match /orders/{orderId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isSignedIn() && isValidOrder(incoming());
      allow delete: if isSuperAdmin() || (isSignedIn() && isTenantAdmin(resource.data.tenantId));
    }

    // -------------------------------------------------------------------------
    // 6. Finance & Inventory Tools
    // -------------------------------------------------------------------------
    
    match /bank_accounts/{accountId} {
      allow read, list: if true; // Public payment methods in catalog
      allow write: if isSignedIn();
    }

    match /warehouses/{warehouseId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn() && isTenantStaff(incoming().tenantId);
    }

    match /stock_logs/{logId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidStockLog(incoming());
      allow update, delete: if isSuperAdmin();
    }

    match /stock_opnames/{opnameId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // -------------------------------------------------------------------------
    // 7. Purchasing
    // -------------------------------------------------------------------------
    
    match /suppliers/{supplierId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /purchase_requests/{prId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /purchase_orders/{poId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /goods_receipts/{grId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /purchase_invoices/{piId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    // -------------------------------------------------------------------------
    // 8. Daily Closings & Misc
    // -------------------------------------------------------------------------
    
    match /dailyClosings/{closingId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }

    match /sales_targets/{targetId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /expenseRules/{ruleId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /approval_requests/{requestId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin() || (isSignedIn() && isTenantAdmin(resource.data.tenantId));
    }

    match /delete_requests/{requestId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin() || (isSignedIn() && isTenantAdmin(resource.data.tenantId));
    }

    match /charityRecords/{charityId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin() || (isSignedIn() && isTenantAdmin(resource.data.tenantId));
    }

    match /invoice_collections/{collectionId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin() || (isSignedIn() && isTenantAdmin(resource.data.tenantId));
    }

    match /payment_receipts/{receiptId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin() || (isSignedIn() && isTenantAdmin(resource.data.tenantId));
    }

    match /payment_corrections/{correctionId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin() || (isSignedIn() && isTenantAdmin(resource.data.tenantId));
    }

    match /counters/{counterId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /coupons/{couponId} {
      allow read, list: if true; 
      allow create, delete: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
      allow update: if isSuperAdmin() || (isSignedIn() && (
        isTenantStaff(existing().tenantId) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['usedCount']) && 
         incoming().usedCount == existing().usedCount + 1)
      ));
    }

    match /tenant_coupons/{couponId} {
      allow read, list: if isSignedIn();
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || (
        isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['usedCount'])
      );
    }

    match /customers/{customerId} {
      allow read, list: if isSignedIn() && (
        isSuperAdmin() || 
        (existing().uid == request.auth.uid) ||
        (userExists() && existing().tenantId == getTenantId())
      );
      allow create: if isSignedIn() && (
        isSuperAdmin() || 
        (incoming().uid == request.auth.uid) ||
        (isTenantStaff(incoming().tenantId) && isValidCustomer(incoming()))
      );
      allow update: if isSignedIn() && (
        isSuperAdmin() || 
        (existing().uid == request.auth.uid) ||
        (userExists() && existing().tenantId == getTenantId() && isValidCustomer(incoming()))
      );
      allow delete: if isSuperAdmin() || (isSignedIn() && isTenantStaff(existing().tenantId));
    }

    match /customer_categories/{categoryId} {
      allow read, list: if isSignedIn();
      allow create, update: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
      allow delete: if isSuperAdmin() || (isSignedIn() && isTenantStaff(existing().tenantId));
    }

    match /finance_invoices/{invoiceId} {
      allow read, list: if isSignedIn();
      allow create: if isSuperAdmin() || (isSignedIn() && (incoming().userId == request.auth.uid || isTenantStaff(incoming().tenantId)));
      allow update: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
      allow delete: if isSuperAdmin() || (isSignedIn() && isTenantAdmin(resource.data.tenantId));
    }

    match /roles/{roleId} {
      allow read, list: if isSignedIn();
      allow write: if isSuperAdmin() || (isSignedIn() && isTenantAdmin(incoming().tenantId));
    }

    match /bookings/{bookingId} {
      allow read, write: if isSignedIn();
    }

    // System configurations
    match /custom_domains/{domainId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /mail/{mailId} {
      allow read: if isSuperAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }

    match /system_services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /system/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /system_roadmap/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    // -------------------------------------------------------------------------
    // 9. Activity Logs
    // -------------------------------------------------------------------------
    
    match /activity_logs/{logId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }
  }
}
