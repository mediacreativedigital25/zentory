rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: tenants
    // Fields: id, name, email, phone, address, status, plan, createdAt
    //
    // Collection: users
    // Fields: uid, name, email, phone, address, role, tenantId, createdAt
    //
    // Collection: products
    // Fields: id, tenantId, name, description, price, stock, image, createdAt
    //
    // Collection: orders
    // Fields: id, tenantId, customerId, customerName, items, total, status, type, createdAt
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'SuperAdmin' || 
         request.auth.token.email == 'mediacreativedigital25@gmail.com');
    }
    
    function getTenantId() {
      return getUserData().tenantId;
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'Administrator';
    }
    
    function isManager() {
      return hasRole('Admin 01 Manager Bisnis');
    }
    
    function isCashier() {
      return hasRole('Admin 02 Kasir');
    }
    
    function isStaff() {
      return isSuperAdmin() || isAdmin() || isManager() || isCashier();
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function sameTenant(data) {
      return isSuperAdmin() || (data.tenantId == getTenantId());
    }

    // Tenants Collection
    match /tenants/{tenantId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isSuperAdmin();
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow create: if isAuthenticated(); 
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin() || isSuperAdmin());
      allow delete: if isAdmin() || isSuperAdmin();
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true; 
      allow create, update, delete: if (isAdmin() || isManager() || isSuperAdmin()) && sameTenant(request.resource.data);
    }

    // Categories Collection
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if (isAdmin() || isManager() || isSuperAdmin()) && sameTenant(request.resource.data);
    }

    // Orders Collection
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (isStaff() || resource.data.customerId == request.auth.uid) && sameTenant(resource.data);
      allow create: if isAuthenticated() && sameTenant(request.resource.data);
      allow update: if isAuthenticated() && (isStaff() || (isOwner(resource.data.customerId) && resource.data.status == 'Pending')) && sameTenant(request.resource.data);
      allow delete: if isAdmin() || isSuperAdmin();
    }
    // Services
    match /services/{serviceId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || (isAuthenticated() && sameTenant(request.resource.data.tenantId));
    }

    // Bookings
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || sameTenant(resource.data.tenantId));
      allow create: if isAuthenticated() && sameTenant(request.resource.data.tenantId);
      allow update: if isAuthenticated() && sameTenant(resource.data.tenantId);
      allow delete: if isSuperAdmin();
    }

    // Transactions
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || sameTenant(resource.data.tenantId));
      allow write: if isSuperAdmin() || (isAuthenticated() && sameTenant(request.resource.data.tenantId));
    }
  }
}
