rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin') || 
        (request.auth.token.email == "mediacreativedigital25@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    
    function isTenantAdmin(tenantId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isTenantStaff(tenantId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff');
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
    }

    match /tenants/{tenantId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow delete: if isSuperAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(request.resource.data.tenantId));
      allow update: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow delete: if isAuthenticated() && (isSuperAdmin() || isTenantAdmin(resource.data.tenantId));
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow create: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(request.resource.data.tenantId));
      allow update: if isAuthenticated() && (isSuperAdmin() || isTenantAdmin(resource.data.tenantId));
      allow delete: if isSuperAdmin();
    }

    // Customers
    match /customers/{customerId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow write: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(request.resource.data.tenantId));
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow write: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(request.resource.data.tenantId));
    }

    // Warehouses
    match /warehouses/{warehouseId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow write: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(request.resource.data.tenantId));
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow create: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(request.resource.data.tenantId));
      allow update: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
    }
  }
}
