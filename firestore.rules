rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "mediacreativedigital25@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin')
      );
    }

    function hasPermission(permission) {
      return isAuthenticated() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isTenantAdmin(tenantId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'kasir' || 
              hasPermission('tenant_settings'));
    }
    
    function isTenantStaff(tenantId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'customer';
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        isSuperAdmin() || 
        (resource != null && resource.data.tenantId != null && isTenantStaff(resource.data.tenantId))
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == userId || 
        isSuperAdmin() || 
        (request.resource.data.tenantId != null && isTenantAdmin(request.resource.data.tenantId))
      );
      allow update: if isAuthenticated() && (
        request.auth.uid == userId || 
        isSuperAdmin() || 
        (resource != null && resource.data.tenantId != null && isTenantAdmin(resource.data.tenantId))
      );
      allow delete: if isSuperAdmin() || (isAuthenticated() && resource != null && resource.data.tenantId != null && isTenantAdmin(resource.data.tenantId));
    }

    match /roles/{roleId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || (resource != null && isTenantStaff(resource.data.tenantId)) || !exists(/databases/$(database)/documents/roles/$(roleId)));
      allow write: if isAuthenticated() && (
        isSuperAdmin() || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
            (request.method == 'create' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == request.resource.data.tenantId) ||
            (request.method != 'create' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == resource.data.tenantId)
          ) && (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
            hasPermission('master_roles')
          )
        )
      );
    }

    match /tenants/{tenantId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow delete: if isSuperAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(request.resource.data.tenantId));
      allow update: if isAuthenticated() && (
        isSuperAdmin() || 
        (resource != null && isTenantStaff(resource.data.tenantId)) ||
        (resource != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']))
      );
      allow delete: if isAuthenticated() && (isSuperAdmin() || (resource != null && isTenantAdmin(resource.data.tenantId)));
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || (resource != null && isTenantStaff(resource.data.tenantId)));
      allow create: if isAuthenticated() && (
        isSuperAdmin() || 
        isTenantStaff(request.resource.data.tenantId) ||
        (request.resource.data.type == 'sale' && request.resource.data.status == 'pending')
      );
      allow update: if isAuthenticated() && (isSuperAdmin() || (resource != null && isTenantStaff(resource.data.tenantId)));
      allow delete: if isSuperAdmin();
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated() && (
        (resource != null && resource.data.uid == request.auth.uid) ||
        isSuperAdmin() || 
        (resource != null && isTenantStaff(resource.data.tenantId))
      );
      allow create: if isAuthenticated() && (
        (request.resource.data.uid == request.auth.uid) ||
        (request.resource.data.email == request.auth.token.email) ||
        isSuperAdmin() || 
        isTenantStaff(request.resource.data.tenantId)
      );
      allow update: if isAuthenticated() && (
        (resource != null && resource.data.uid == request.auth.uid) ||
        isSuperAdmin() || 
        (resource != null && isTenantStaff(resource.data.tenantId))
      );
    }

    match /categories/{categoryId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow write: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(request.resource.data.tenantId));
    }

    match /warehouses/{warehouseId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow write: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(request.resource.data.tenantId));
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        isTenantStaff(resource.data.tenantId) || 
        (resource.data.userId == request.auth.uid)
      );
      allow create: if isAuthenticated() && (
        isSuperAdmin() || 
        isTenantStaff(request.resource.data.tenantId) || 
        (request.resource.data.userId == request.auth.uid)
      );
      allow update: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow delete: if isSuperAdmin();
    }

    match /approval_requests/{requestId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow create: if isAuthenticated() && isTenantStaff(request.resource.data.tenantId);
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /dailyClosings/{closingId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow create: if isAuthenticated() && isTenantStaff(request.resource.data.tenantId);
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /expenseRules/{ruleId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow write: if isAuthenticated() && (isSuperAdmin() || isTenantAdmin(request.resource.data.tenantId));
    }

    match /charityRecords/{charityId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow create: if isAuthenticated() && isTenantStaff(request.resource.data.tenantId);
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /bank_accounts/{accountId} {
      allow read: if true;
      allow write: if isAuthenticated() && (
        isSuperAdmin() || (
          (request.method == 'create' && isTenantAdmin(request.resource.data.tenantId)) ||
          (request.method != 'create' && isTenantAdmin(resource.data.tenantId))
        )
      );
    }

    match /suppliers/{supplierId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow write: if isAuthenticated() && (
        isSuperAdmin() || 
        ((request.method == 'create' && isTenantAdmin(request.resource.data.tenantId)) || (request.method != 'create' && isTenantAdmin(resource.data.tenantId))) || 
        hasPermission('purchase_suppliers')
      );
    }

    match /purchase_requests/{prId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow write: if isAuthenticated() && (
        isSuperAdmin() || 
        ((request.method == 'create' && isTenantStaff(request.resource.data.tenantId)) || (request.method != 'create' && isTenantStaff(resource.data.tenantId))) || 
        hasPermission('purchase_requests')
      );
    }

    match /purchase_orders/{poId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow write: if isAuthenticated() && (
        isSuperAdmin() || 
        ((request.method == 'create' && isTenantStaff(request.resource.data.tenantId)) || (request.method != 'create' && isTenantStaff(resource.data.tenantId))) || 
        hasPermission('purchase_orders')
      );
    }

    match /goods_receipts/{grId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow write: if isAuthenticated() && (
        isSuperAdmin() || 
        ((request.method == 'create' && isTenantStaff(request.resource.data.tenantId)) || (request.method != 'create' && isTenantStaff(resource.data.tenantId))) || 
        hasPermission('purchase_goods_receipts')
      );
    }

    match /purchase_invoices/{piId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow write: if isAuthenticated() && (
        isSuperAdmin() || 
        ((request.method == 'create' && isTenantStaff(request.resource.data.tenantId)) || (request.method != 'create' && isTenantStaff(resource.data.tenantId))) || 
        hasPermission('purchase_invoices')
      );
    }

    match /custom_domains/{domainId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /system_roadmap/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /system/{configId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /stock_logs/{logId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || (resource != null && isTenantStaff(resource.data.tenantId)));
      allow create: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(request.resource.data.tenantId));
      allow update, delete: if isSuperAdmin();
    }

    match /finance_invoices/{invoiceId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || (resource != null && isTenantStaff(resource.data.tenantId)));
      allow create: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(request.resource.data.tenantId));
      allow update: if isAuthenticated() && (isSuperAdmin() || (resource != null && isTenantStaff(resource.data.tenantId)));
      allow delete: if isSuperAdmin();
    }

    match /system_services/{serviceId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow update: if isAuthenticated() && (
        isSuperAdmin() || 
        isTenantStaff(resource.data.tenantId) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedCount']) && 
         request.resource.data.usedCount == resource.data.usedCount + 1)
      );
      allow create, delete: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(request.resource.data.tenantId));
    }

    match /stock_opnames/{opnameId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(resource.data.tenantId));
      allow create: if isAuthenticated() && (isSuperAdmin() || isTenantStaff(request.resource.data.tenantId));
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && isTenantAdmin(resource.data.tenantId));
    }
  }
}
