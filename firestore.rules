rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // 1. Primitive Definitions & Helpers
    // -------------------------------------------------------------------------
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    
    // User profile lookup
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    // Super Admin: hardcoded email or role 'superadmin'
    function isSuperAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == "mediacreativedigital25@gmail.com" && isEmailVerified()) ||
        (userExists() && getUserData().role == 'superadmin')
      );
    }

    // Tenant Isolation Helpers
    function getTenantId() {
      return getUserData().tenantId;
    }
    
    function isTenantAdmin(tenantId) {
      return isSignedIn() && userExists() && 
             getUserData().tenantId == tenantId && 
             getUserData().role == 'admin';
    }
    
    function isTenantStaff(tenantId) {
      return isSignedIn() && userExists() && 
             getUserData().tenantId == tenantId && 
             (getUserData().role == 'admin' || getUserData().role == 'staff' || getUserData().role == 'kasir');
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // 2. Tenants (Publicly browsable for catalogs, but only staff/superadmin can list all)
    // -------------------------------------------------------------------------
    
    match /tenants/{tenantId} {
      allow read: if true; // Catalogs need to find the tenant by slug/id
      allow create: if isSignedIn() && isEmailVerified() && incoming().ownerId == request.auth.uid;
      allow update: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow delete: if isSuperAdmin();
    }

    // -------------------------------------------------------------------------
    // 3. User Profiles
    // -------------------------------------------------------------------------
    
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || 
        isSuperAdmin() || 
        (userExists() && existing().tenantId != null && existing().tenantId == getTenantId())
      );
      
      allow create: if isSignedIn() && (
        request.auth.uid == userId || 
        isSuperAdmin() || 
        (incoming().tenantId != null && isTenantAdmin(incoming().tenantId))
      );
      
      allow update: if isSignedIn() && (
        isSuperAdmin() || 
        // Users can update their own displayName and presence, but NOT role or tenantId
        (request.auth.uid == userId && 
         incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'lastLoginAt', 'isOnline', 'lastLogoutAt', 'forceLogoutAt', 'address'])) ||
        // Tenant admins can update roles within their tenant
        (existing().tenantId != null && isTenantAdmin(existing().tenantId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['role', 'displayName']))
      );
      
      allow delete: if isSuperAdmin() || (isSignedIn() && existing().tenantId != null && isTenantAdmin(existing().tenantId));
    }

    // -------------------------------------------------------------------------
    // 4. Products & Categories (Public for Catalogs)
    // -------------------------------------------------------------------------
    
    match /products/{productId} {
      allow read, list: if true; 
      allow create: if (isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId)));
      allow update: if isSuperAdmin() || (
        isSignedIn() && resource.data.tenantId == getTenantId() && (
          isTenantStaff(resource.data.tenantId) ||
          incoming().diff(existing()).affectedKeys().hasOnly(['stock'])
        )
      );
      allow delete: if isSuperAdmin() || (isSignedIn() && isTenantAdmin(resource.data.tenantId));
    }

    match /categories/{categoryId} {
      allow read, list: if true;
      allow write: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
    }

    // -------------------------------------------------------------------------
    // 5. Transactions & Orders (Private)
    // -------------------------------------------------------------------------
    
    match /transactions/{transactionId} {
      allow read, list: if isSuperAdmin() || (isSignedIn() && userExists() && resource.data.tenantId == getTenantId());
      allow create: if isSuperAdmin() || (isSignedIn() && (
        isTenantStaff(incoming().tenantId) || 
        (incoming().type == 'sale' && incoming().status == 'pending')
      ));
      allow update: if isSuperAdmin() || (isSignedIn() && isTenantStaff(resource.data.tenantId));
      allow delete: if isSuperAdmin();
    }

    match /orders/{orderId} {
      allow read, list: if isSuperAdmin() || (isSignedIn() && userExists() && (
        isTenantStaff(resource.data.tenantId) || 
        resource.data.userId == request.auth.uid
      ));
      allow create: if isSuperAdmin() || (isSignedIn() && (
        isTenantStaff(incoming().tenantId) || 
        incoming().userId == request.auth.uid
      ));
      allow update: if isSuperAdmin() || (isSignedIn() && isTenantStaff(resource.data.tenantId));
      allow delete: if isSuperAdmin();
    }

    // -------------------------------------------------------------------------
    // 6. Finance & Inventory Tools
    // -------------------------------------------------------------------------
    
    match /bank_accounts/{accountId} {
      allow read, list: if true; // Public payment methods in catalog
      allow write: if isSuperAdmin() || (
        isSignedIn() && (
          (request.method == 'create' && isTenantAdmin(incoming().tenantId)) ||
          (request.method != 'create' && isTenantAdmin(existing().tenantId))
        )
      );
    }

    match /warehouses/{warehouseId} {
      allow read, list: if isSuperAdmin() || (isSignedIn() && userExists() && resource.data.tenantId == getTenantId());
      allow write: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
    }

    match /stock_logs/{logId} {
      allow read, list: if isSuperAdmin() || (isSignedIn() && userExists() && resource.data.tenantId == getTenantId());
      allow create: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
      allow update, delete: if isSuperAdmin();
    }

    match /stock_opnames/{opnameId} {
      allow read, list: if isSuperAdmin() || (isSignedIn() && userExists() && resource.data.tenantId == getTenantId());
      allow create: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
      allow update, delete: if isSuperAdmin() || (isSignedIn() && isTenantAdmin(existing().tenantId));
    }

    // -------------------------------------------------------------------------
    // 7. Purchasing
    // -------------------------------------------------------------------------
    
    match /suppliers/{supplierId} {
      allow read, list: if isSuperAdmin() || (isSignedIn() && userExists() && resource.data.tenantId == getTenantId());
      allow write: if isSuperAdmin() || (isSignedIn() && isTenantAdmin(incoming().tenantId));
    }

    match /purchase_requests/{prId} {
      allow read, list: if isSuperAdmin() || (isSignedIn() && userExists() && resource.data.tenantId == getTenantId());
      allow write: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
    }

    match /purchase_orders/{poId} {
      allow read, list: if isSuperAdmin() || (isSignedIn() && userExists() && resource.data.tenantId == getTenantId());
      allow write: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
    }

    match /goods_receipts/{grId} {
      allow read, list: if isSuperAdmin() || (isSignedIn() && userExists() && resource.data.tenantId == getTenantId());
      allow write: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
    }

    match /purchase_invoices/{piId} {
      allow read, list: if isSuperAdmin() || (isSignedIn() && userExists() && resource.data.tenantId == getTenantId());
      allow write: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
    }

    // -------------------------------------------------------------------------
    // 8. Daily Closings & Misc
    // -------------------------------------------------------------------------
    
    match /dailyClosings/{closingId} {
      allow read, list: if isSuperAdmin() || (isSignedIn() && userExists() && resource.data.tenantId == getTenantId());
      allow create: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
      allow update, delete: if isSuperAdmin();
    }

    match /expenseRules/{ruleId} {
      allow read, list: if isSuperAdmin() || (isSignedIn() && userExists() && resource.data.tenantId == getTenantId());
      allow write: if isSuperAdmin() || (isSignedIn() && isTenantAdmin(incoming().tenantId));
    }

    match /approval_requests/{requestId} {
      allow read, list: if isSuperAdmin() || (isSignedIn() && userExists() && resource.data.tenantId == getTenantId());
      allow create: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
      allow update, delete: if isSuperAdmin();
    }

    match /charityRecords/{charityId} {
      allow read, list: if isSuperAdmin() || (isSignedIn() && userExists() && resource.data.tenantId == getTenantId());
      allow create: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
      allow update: if isSuperAdmin() || (isSignedIn() && isTenantStaff(resource.data.tenantId));
      allow delete: if isSuperAdmin();
    }

    match /coupons/{couponId} {
      allow read, list: if true; 
      allow create, delete: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
      allow update: if isSuperAdmin() || (isSignedIn() && (
        isTenantStaff(existing().tenantId) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['usedCount']) && 
         incoming().usedCount == existing().usedCount + 1)
      ));
    }

    match /customers/{customerId} {
      allow read, list: if isSignedIn() && (
        isSuperAdmin() || 
        (resource.data.uid == request.auth.uid) ||
        (userExists() && resource.data.tenantId == getTenantId())
      );
      allow create: if isSignedIn() && (
        isSuperAdmin() || 
        (incoming().uid == request.auth.uid) ||
        isTenantStaff(incoming().tenantId)
      );
      allow update: if isSignedIn() && (
        isSuperAdmin() || 
        (resource.data.uid == request.auth.uid) ||
        (userExists() && resource.data.tenantId == getTenantId())
      );
    }

    match /finance_invoices/{invoiceId} {
      allow read, list: if isSuperAdmin() || (isSignedIn() && userExists() && resource.data.tenantId == getTenantId());
      allow create, update: if isSuperAdmin() || (isSignedIn() && isTenantStaff(incoming().tenantId));
      allow delete: if isSuperAdmin();
    }

    match /roles/{roleId} {
      allow read, list: if isSuperAdmin() || (isSignedIn() && userExists() && resource.data.tenantId == getTenantId());
      allow write: if isSuperAdmin() || (isSignedIn() && isTenantAdmin(incoming().tenantId));
    }

    // System configurations
    match /custom_domains/{domainId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /system_services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /system/{configId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}
